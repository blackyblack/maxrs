{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug maxrs CLI",
            "cargo": {
                "args": [
                    "build",
                    "--example",
                    "cli"
                ],
                "filter": {
                    "name": "cli",
                    "kind": "example"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "RUST_BACKTRACE": "1",
                "MAX_CALLBACK_BIND": "0.0.0.0:3002",
                "MAX_CALLBACK_URL_BASE": "http://host.docker.internal:3002"
            },
            "console": "integratedTerminal"
        }
    ]
}
