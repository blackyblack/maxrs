{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cargo build --example cli",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--example",
                "cli"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
